{
  "name": "@theotherwillembotha/nodered_nginxproxymanager",
  "version": "1.0.0",
  "description": "An NginX Proxy Manager plugin for nodered",
  "exports": "./build/index.js",
  "author": "Willem Botha",
  "license": "ISC",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run clean && tsc && npm run generate-nodes && npm run copy-files",
    "clean": "rm -rf ./build",
    "generate-nodes": "node build/GenerateNodes.js",
    "copy-files": "cp -r ./icons ./build/"
  },
  "dependencies": {
    "nginx-proxy-manager-sdk": "^0.1.1"
  },
  "devDependencies": {
    "@theotherwillembotha/nodered_plugincore": "../nodered_plugincore",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.15.16",
    "@types/node-red": "~1.3.5"
  },
  "node-red": {
    "nodes": {
      "nginx": "./build/Nodes.js"
    },
    "plugins": {
      "nginx": "./build/Plugins.js"
    }
  }
}
