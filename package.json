    "md5": "^2.3.0",
    "network": "^0.7.0",
    "nginx-proxy-manager-sdk": "^0.1.1",
    "prom-client": "^15.1.1",
    "tough-cookie": "^5.1.2",
    "whatwg-url": "^14.2.0",
    "winston": "^3.17.0",
    "winston-loki": "^6.1.3",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@theotherwillembotha/nodered_plugincore": "../nodered_plugincore",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.15.16",
    "@types/node-red": "~1.3.5",
    "@types/whatwg-url": "^13.0.0",
    "@types/ws": "^8.18.1"
  },
  "node-red": {
